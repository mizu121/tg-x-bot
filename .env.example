BOT_TOKEN=
APIFY_TOKEN=
APIFY_MAX_CHARGE_USD=0.05
ADMIN_CHAT_IDS=

# Runtime safety limits
MAX_CONCURRENT_DOWNLOADS=1
MAX_UPLOAD_MB=49
SEND_AS_DOCUMENT_MB=45
MAX_REELS_PER_REQUEST=5
DOWNLOAD_TTL_MINUTES=90
DOWNLOAD_MAX_TOTAL_MB=600
PROGRESS_INTERVAL_SECONDS=0.9
PROGRESS_FRAMES=>>>>>-----
REQUEST_TIMEOUT_SECONDS=90
TELEGRAM_MESSAGE_EFFECT_ID=
LOADER_STICKER_FILE_ID=
LOADER_ANIMATION_FILE_ID=
TELEGRAM_SAFE_VIDEO_TRANSCODE=true
VIDEO_TRANSCODE_CRF=28
VIDEO_TRANSCODE_PRESET=ultrafast
VIDEO_TRANSCODE_MAX_WIDTH=720
VIDEO_TRANSCODE_MAX_HEIGHT=1280
VIDEO_TRANSCODE_THREADS=1
VIDEO_TRANSCODE_TIMEOUT_SECONDS=240
DOWNLOAD_DIR=downloads
FAILURE_LOG_PATH=logs/failures.jsonl
FAILURE_LOG_MAX_ENTRIES=100
MESSAGE_LOG_PATH=logs/messages.jsonl
MESSAGE_LOG_MAX_ENTRIES=500
LOG_FULL_URLS=false
LOG_TRACEBACKS=false
LOG_LEVEL=INFO

# Default keeps downloads smaller than "best" while allowing fallbacks when mp4 is unavailable.
YTDLP_FORMAT=bv*[height<=720]+ba/b[height<=720]/best[height<=720]/best
YOUTUBE_CLIENTS=mweb,web_safari,android,web
YOUTUBE_FALLBACK_CLIENTS=android,web;web_safari;tv;ios
YOUTUBE_PO_PROVIDER=http
# Optional when using a bgutil HTTP provider:
# YOUTUBE_BGUTIL_BASE_URL=http://127.0.0.1:4416
# Render private service helper, used when YOUTUBE_BGUTIL_BASE_URL is empty:
# YOUTUBE_BGUTIL_HOSTPORT=tg-x-bot-bgutil:4416
# Optional when using a bgutil script provider:
# YOUTUBE_BGUTIL_SERVER_HOME=/app/bgutil-ytdlp-pot-provider/server

# Optional: mount a Netscape cookie file as a secret and point yt-dlp at it.
# Required when YouTube says "Sign in to confirm you're not a bot".
# Do not commit cookie files.
# YTDLP_COOKIE_FILE=/run/secrets/ytdlp_cookies.txt
# Or store a base64 Netscape cookie file in host secrets:
# YTDLP_COOKIES_B64=
