BOT_TOKEN=
APIFY_TOKEN=
APIFY_MAX_CHARGE_USD=0.05
ADMIN_CHAT_IDS=

# Runtime safety limits
MAX_CONCURRENT_DOWNLOADS=1
MAX_UPLOAD_MB=49
SEND_AS_DOCUMENT_MB=45
MAX_REELS_PER_REQUEST=5
DOWNLOAD_TTL_MINUTES=90
DOWNLOAD_MAX_TOTAL_MB=600
PROGRESS_INTERVAL_SECONDS=2.5
REQUEST_TIMEOUT_SECONDS=90
DOWNLOAD_DIR=downloads
FAILURE_LOG_PATH=logs/failures.jsonl
FAILURE_LOG_MAX_ENTRIES=100
LOG_FULL_URLS=false
LOG_TRACEBACKS=false
LOG_LEVEL=INFO

# Default keeps downloads smaller than "best" while allowing fallbacks when mp4 is unavailable.
YTDLP_FORMAT=bv*[height<=720]+ba/b[height<=720]/best[height<=720]/best

# Optional: mount a cookie file as a secret and point yt-dlp at it.
# Do not commit cookie files.
# YTDLP_COOKIE_FILE=/run/secrets/ytdlp_cookies.txt
